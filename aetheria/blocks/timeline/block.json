{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "aetheria/timeline",
  "version": "1.0.0",
  "title": "Timeline",
  "category": "aetheria",
  "icon": "clock",
  "description": "Timeline of events",
