{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "aetheria/stats",
  "version": "1.0.0",
  "title": "Stats",
  "category": "aetheria",
  "icon": "chart-bar",
  "description": "Display statistics with values and labels",
  "supports": {
    "anchor": true,
    "align": ["wide", "full"],
    "html": false
  },
  "attributes": {
    "stats": {
      "type": "array",
      "default": []
    },
    "style": {
      "type": "string",
      "default": "minimal"
    },
    "align": {
      "type": "string",
      "default": "center"
    }
  },
  "textdomain": "aetheria",
  "render": "file:./render.php"
}
