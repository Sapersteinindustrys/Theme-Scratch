{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "aetheria/tabs",
  "version": "1.0.0",
  "title": "Tabs",
  "category": "aetheria",
  "icon": "table-col-after",
  "description": "Tabbed content interface",
  "attributes": {
    "tabs": {
      "type": "array",
      "default": []
    },
    "activation": {
      "type": "string",
      "default": "auto"
    },
    "orientation": {
      "type": "string",
      "default": "horizontal"
    }
  },
  "textdomain": "aetheria",
  "render": "file:./render.php"
}
